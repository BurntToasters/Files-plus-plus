<Window
    x:Class="FilesPlusPlus.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FilesPlusPlus.App.ViewModels"
    xmlns:models="using:FilesPlusPlus.Core.Models">

    
    <Grid x:Name="RootGrid" Background="Transparent">
        <!-- Why: Transparent root allows the native window backdrop to render consistently with MainWindow. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarHost" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Border x:Name="TitleBarDragRegion" Grid.Column="1" Margin="12,6,12,0" CornerRadius="10" Background="{ThemeResource ShellTitleBarBackgroundBrush}" BorderBrush="{ThemeResource ShellTitleBarBorderBrush}" BorderThickness="1">
                <Grid>
                    <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                    <Grid Padding="14,0,14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE713;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ShellTitleBarForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="Files++ Settings" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellTitleBarForegroundBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="Preferences" FontSize="11" Foreground="{ThemeResource ShellTitleBarSecondaryForegroundBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="{ThemeResource ShellTopChromeScrimBrush}" IsHitTestVisible="False" />

        
        <!-- Section: Settings navigation host -->
        <NavigationView
            Grid.Row="1"
            x:Name="SettingsNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="200"
            Background="Transparent"
            SelectionChanged="SettingsNav_SelectionChanged">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewItemBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#22FFFFFF" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="#33FFFFFF" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#33FFFFFF" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#44FFFFFF" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#55FFFFFF" />
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="appearance" Content="Appearance" Icon="Font" />
                <NavigationViewItem Tag="view" Content="View" Icon="ViewAll" />
                <NavigationViewItem Tag="navigation" Content="Navigation" Icon="Globe" />
                <NavigationViewItem Tag="sidebar" Content="Sidebar" Icon="List" />
                <NavigationViewItem Tag="shortcuts" Content="Shortcuts" Icon="Keyboard" />
            </NavigationView.MenuItems>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Padding="16,16,16,16">
                    <Border CornerRadius="10" Background="{ThemeResource ShellSurfaceBackgroundBrush}" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" BorderThickness="1">
                        <Grid Padding="24,20,24,20">
                            <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />

                            
                            <!-- Section: Appearance -->
                            <StackPanel x:Name="AppearancePanel" Spacing="20">
                                <TextBlock Text="Appearance" FontSize="20" FontWeight="SemiBold" />

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Theme" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <RadioButton Content="Use system" IsChecked="{x:Bind ViewModel.IsThemeSystem, Mode=TwoWay}" GroupName="ThemeMode" />
                                        <RadioButton Content="Light" IsChecked="{x:Bind ViewModel.IsThemeLight, Mode=TwoWay}" GroupName="ThemeMode" />
                                        <RadioButton Content="Dark" IsChecked="{x:Bind ViewModel.IsThemeDark, Mode=TwoWay}" GroupName="ThemeMode" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Accent color" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border x:Name="AccentSwatch" Width="40" Height="32" CornerRadius="6" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" BorderThickness="1" />
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Change..." Click="AccentPicker_Click" />
                                        <TextBox Text="{x:Bind ViewModel.AccentHex, Mode=TwoWay}" Width="120" PlaceholderText="#FF1F8FE6" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Density" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ComboBox ItemsSource="{x:Bind ViewModel.DensityOptions}" SelectedItem="{x:Bind ViewModel.Density, Mode=TwoWay}" MinWidth="180" />
                                </StackPanel>
                            </StackPanel>

                            
                            <!-- Section: View -->
                            <StackPanel x:Name="ViewPanel" Spacing="20" Visibility="Collapsed">
                                <TextBlock Text="View" FontSize="20" FontWeight="SemiBold" />

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Default view mode" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ComboBox ItemsSource="{x:Bind ViewModel.ViewModeOptions}" SelectedItem="{x:Bind ViewModel.DefaultViewMode, Mode=TwoWay}" MinWidth="180" />
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Default sort column" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ComboBox ItemsSource="{x:Bind ViewModel.SortColumnOptions}" SelectedItem="{x:Bind ViewModel.DefaultSortColumn, Mode=TwoWay}" MinWidth="180" />
                                    <ToggleSwitch Header="Sort descending by default" IsOn="{x:Bind ViewModel.DefaultSortDescending, Mode=TwoWay}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <ToggleSwitch Header="Show hidden files" IsOn="{x:Bind ViewModel.ShowHiddenFiles, Mode=TwoWay}" />
                                    <ToggleSwitch Header="Show file extensions" IsOn="{x:Bind ViewModel.ShowFileExtensions, Mode=TwoWay}" />
                                    <ToggleSwitch Header="Group folders before files" IsOn="{x:Bind ViewModel.GroupByDirectory, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>

                            
                            <!-- Section: Navigation -->
                            <StackPanel x:Name="NavigationPanel" Spacing="20" Visibility="Collapsed">
                                <TextBlock Text="Navigation" FontSize="20" FontWeight="SemiBold" />

                                <StackPanel Spacing="8">
                                    <TextBlock Text="When Files++ launches" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <RadioButton Content="Restore previous tabs" IsChecked="{x:Bind ViewModel.IsStartupRestore, Mode=TwoWay}" GroupName="StartupBehavior" />
                                    <RadioButton Content="Open Home folder" IsChecked="{x:Bind ViewModel.IsStartupHome, Mode=TwoWay}" GroupName="StartupBehavior" />
                                    <RadioButton Content="Open a specific folder" IsChecked="{x:Bind ViewModel.IsStartupSpecific, Mode=TwoWay}" GroupName="StartupBehavior" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="28,0,0,0">
                                        <TextBox Text="{x:Bind ViewModel.StartupPath, Mode=TwoWay}" PlaceholderText="C:\Users\..." Width="320" />
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Browse..." Click="StartupPath_Click" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="Open items with" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <RadioButton Content="Double click" IsChecked="{x:Bind ViewModel.IsOpenDoubleClick, Mode=TwoWay}" GroupName="OpenItem" />
                                    <RadioButton Content="Single click" IsChecked="{x:Bind ViewModel.IsOpenSingleClick, Mode=TwoWay}" GroupName="OpenItem" />
                                </StackPanel>

                                <ToggleSwitch Header="Confirm before deleting" IsOn="{x:Bind ViewModel.ConfirmDelete, Mode=TwoWay}" />
                            </StackPanel>

                            
                            <!-- Section: Sidebar -->
                            <StackPanel x:Name="SidebarPanel" Spacing="20" Visibility="Collapsed">
                                <TextBlock Text="Sidebar" FontSize="20" FontWeight="SemiBold" />

                                <ToggleSwitch Header="Show drives in sidebar" IsOn="{x:Bind ViewModel.ShowDrives, Mode=TwoWay}" />

                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Grid.Column="0"
                                        Height="320"
                                        CornerRadius="10"
                                        Background="{ThemeResource ShellInputBackgroundBrush}"
                                        BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                                        BorderThickness="1">
                                        <Grid>
                                            <Rectangle VerticalAlignment="Top" Height="2" Margin="4,1,4,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                            <ListView
                                                ItemContainerStyle="{StaticResource ShellListViewItemStyle}"
                                                ItemsSource="{x:Bind ViewModel.SidebarPins}"
                                                SelectedItem="{x:Bind ViewModel.SelectedSidebar, Mode=TwoWay}"
                                                Background="Transparent"
                                                BorderThickness="0">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="10,6" ColumnSpacing="10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="22" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="14" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Label}" VerticalAlignment="Center" FontSize="13" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Path}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Top">
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Move up" Width="120" Command="{x:Bind ViewModel.MoveUpCommand}" />
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Move down" Width="120" Command="{x:Bind ViewModel.MoveDownCommand}" />
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Remove" Width="120" Command="{x:Bind ViewModel.RemoveCommand}" />
                                        <Border Height="1" Background="{ThemeResource ShellSurfaceBorderBrush}" Margin="0,4" />
                                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Add folder..." Width="120" Command="{x:Bind ViewModel.AddPinCommand}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            
                            <!-- Section: Shortcuts -->
                            <StackPanel x:Name="ShortcutsPanel" Spacing="20" Visibility="Collapsed">
                                <TextBlock Text="Shortcuts" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="Keyboard shortcuts are read-only in this release." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Border
                                    CornerRadius="10"
                                    Background="{ThemeResource ShellInputBackgroundBrush}"
                                    BorderBrush="{ThemeResource ShellSurfaceBorderBrush}"
                                    BorderThickness="1">
                                    <Grid>
                                        <Rectangle VerticalAlignment="Top" Height="2" Margin="4,1,4,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                        <ListView
                                            ItemsSource="{x:Bind ViewModel.Shortcuts}"
                                            ItemContainerStyle="{StaticResource ShellListViewItemStyle}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            SelectionMode="None">
                                            <ListView.HeaderTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,8" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ShellSubtleBorderBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="200" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="ACTION" FontSize="10" FontWeight="SemiBold" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Grid.Column="1" Text="KEYS" FontSize="10" FontWeight="SemiBold" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.HeaderTemplate>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="14,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="200" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Action}" FontSize="13" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Keys}" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </NavigationView>

        <Border Grid.Row="2" Margin="16,0,16,12" CornerRadius="10" BorderThickness="1" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" Background="{ThemeResource ShellSurfaceBackgroundBrush}">
            <Grid>
                <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                <Grid Padding="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button
                            Style="{StaticResource ShellGlassButtonStyle}"
                            Content="Reset to defaults"
                            Command="{x:Bind ViewModel.ResetCommand}" />
                        <Button
                            Style="{StaticResource ShellGlassPrimaryButtonStyle}"
                            Content="Save"
                            Command="{x:Bind ViewModel.SaveCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

