<Window
    x:Class="FilesPlusPlus.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FilesPlusPlus.App.ViewModels">

    
    <Grid x:Name="RootGrid" Background="Transparent">
        <!-- Why: Root surface stays transparent so the native backdrop provides the window material. -->
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        
        <!-- Section: Top chrome backdrop -->
        <Rectangle Grid.Row="0" Grid.RowSpan="2" Fill="{ThemeResource ShellTopChromeScrimBrush}" IsHitTestVisible="False" />

        
        <!-- Section: Title bar -->
        <Grid x:Name="TitleBarHost" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TitleBarLeftInsetColumn" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="TitleBarRightInsetColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <Border x:Name="TitleBarDragRegion" Grid.Column="1" Margin="12,6,12,0" CornerRadius="10" Background="{ThemeResource ShellTitleBarBackgroundBrush}" BorderBrush="{ThemeResource ShellTitleBarBorderBrush}" BorderThickness="1">
                <Grid>
                    <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                    <Grid Padding="16,0,16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource ShellTitleBarForegroundBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1" Text="Files++" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource ShellTitleBarForegroundBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SelectedTab.Header}" FontSize="11" Foreground="{ThemeResource ShellTitleBarSecondaryForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        
        <!-- Section: Tab strip -->
        <Border Grid.Row="1" Margin="10,3,10,0" CornerRadius="10" Background="{ThemeResource ShellTabStripBackgroundBrush}" BorderBrush="{ThemeResource ShellTabStripBorderBrush}" BorderThickness="1">
            <Grid>
                <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                <Grid Padding="6,4" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        MinWidth="120"
                                        MaxWidth="220"
                                        Height="32"
                                        Padding="0"
                                        Margin="0,0,4,0"
                                        CornerRadius="10,10,0,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        UseSystemFocusVisuals="True"
                                        Click="TabButton_Click"
                                        AutomationProperties.Name="{Binding Header}"
                                        Tag="{Binding}">
                                        <Grid>
                                            
                                            <Border CornerRadius="10,10,0,0" Background="{ThemeResource ShellTabBackgroundBrush}" BorderBrush="{ThemeResource ShellTabBorderBrush}" BorderThickness="1,1,1,0" />
                                            
                                            <Border
                                                CornerRadius="10,10,0,0"
                                                Background="{ThemeResource ShellTabSelectedBackgroundBrush}"
                                                BorderBrush="{ThemeResource ShellTabSelectedBorderBrush}"
                                                BorderThickness="1,1,1,0"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            
                                            <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                            
                                            <Rectangle
                                                VerticalAlignment="Bottom"
                                                Height="2"
                                                Margin="3,0,3,0"
                                                RadiusX="1"
                                                RadiusY="1"
                                                Fill="{ThemeResource ShellTabIndicatorBrush}"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsHitTestVisible="False" />

                                            <Grid Padding="14,3" ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Header}" TextTrimming="CharacterEllipsis" FontSize="12" Foreground="{ThemeResource ShellTabForegroundBrush}" VerticalAlignment="Center" />
                                                <Button
                                                    Grid.Column="1"
                                                    Width="17"
                                                    Height="17"
                                                    Padding="0"
                                                    Click="CloseTab_Click"
                                                    Tag="{Binding}"
                                                    UseSystemFocusVisuals="True"
                                                    AutomationProperties.Name="Close tab"
                                                    FontSize="9"
                                                    Foreground="{ThemeResource ShellTabCloseForegroundBrush}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Content="&#xE711;"
                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}" />
                                            </Grid>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button
                        Grid.Column="1"
                        Style="{StaticResource ShellGlassButtonStyle}"
                        Width="32"
                        Height="32"
                        Padding="0"
                        CornerRadius="16"
                        Click="AddTab_Click"
                        AutomationProperties.Name="Add new tab"
                        ToolTipService.ToolTip="New tab">
                        <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                    </Button>
                </Grid>
            </Grid>
        </Border>

        
        <!-- Section: Toolbar -->
        <Border Grid.Row="2" Margin="10,6,10,4" CornerRadius="10" BorderThickness="1" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" Background="{ThemeResource ShellSurfaceBackgroundBrush}">
            <Grid>
                <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                <Grid Padding="8,6" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
                        <Button x:Name="BackButton" Style="{StaticResource ShellGlassButtonStyle}" Width="32" Height="32" Padding="0" CornerRadius="16" Click="Back_Click" ToolTipService.ToolTip="Back" AutomationProperties.Name="Back" IsEnabled="{Binding SelectedTab.CanGoBack}">
                            <FontIcon Glyph="&#xE72B;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                        </Button>
                        <Button x:Name="ForwardButton" Style="{StaticResource ShellGlassButtonStyle}" Width="32" Height="32" Padding="0" CornerRadius="16" Click="Forward_Click" ToolTipService.ToolTip="Forward" AutomationProperties.Name="Forward" IsEnabled="{Binding SelectedTab.CanGoForward}">
                            <FontIcon Glyph="&#xE72A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                        </Button>
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Width="32" Height="32" Padding="0" CornerRadius="16" Click="Up_Click" ToolTipService.ToolTip="Up" AutomationProperties.Name="Up">
                            <FontIcon Glyph="&#xE74A;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                        </Button>
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Width="32" Height="32" Padding="0" CornerRadius="16" Click="Refresh_Click" ToolTipService.ToolTip="Refresh" AutomationProperties.Name="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="1" Margin="4,0" Padding="14,5" CornerRadius="16" BorderThickness="1" BorderBrush="{ThemeResource ShellInputBorderBrush}" Background="{ThemeResource ShellInputBackgroundBrush}">
                        <BreadcrumbBar x:Name="PathBreadcrumb" ItemsSource="{Binding SelectedTab.Breadcrumbs}" ItemClicked="Breadcrumb_ItemClicked" AutomationProperties.Name="Current path">
                            <BreadcrumbBar.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </BreadcrumbBar.ItemTemplate>
                        </BreadcrumbBar>
                    </Border>

                    <AutoSuggestBox Grid.Column="2" x:Name="SearchBox" PlaceholderText="Search" QueryIcon="Find" QuerySubmitted="Search_QuerySubmitted" TextChanged="Search_TextChanged" Background="{ThemeResource ShellInputBackgroundBrush}" BorderBrush="{ThemeResource ShellInputBorderBrush}" BorderThickness="1" CornerRadius="16" Foreground="{ThemeResource ShellButtonForegroundBrush}" AutomationProperties.Name="Search files in current folder" />
                </Grid>
            </Grid>
        </Border>

        
        <!-- Section: Command strip -->
        <Border Grid.Row="3" Margin="10,0,10,7" CornerRadius="10" BorderThickness="1" BorderBrush="{ThemeResource ShellCommandStripBorderBrush}" Background="{ThemeResource ShellCommandStripBackgroundBrush}">
            <Grid>
                <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                <Grid Padding="8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Style="{StaticResource ShellGlassPrimaryButtonStyle}"
                        Click="CreateFolder_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE710;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="13" Foreground="{ThemeResource ShellCommandPrimaryButtonForegroundBrush}" />
                            <TextBlock Text="Add New" FontWeight="SemiBold" FontSize="11" Foreground="{ThemeResource ShellCommandPrimaryButtonForegroundBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Copy" Click="Copy_Click" />
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Cut" Click="Cut_Click" />
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Paste" Click="Paste_Click" />
                        <ToggleButton x:Name="DetailsViewButton" Style="{StaticResource ShellGlassToggleButtonStyle}" Content="Details" Click="DetailsViewButton_Click" />
                        <ToggleButton x:Name="CompactViewButton" Style="{StaticResource ShellGlassToggleButtonStyle}" Content="Compact" Click="CompactViewButton_Click" />
                        <ToggleButton x:Name="IconsViewButton" Style="{StaticResource ShellGlassToggleButtonStyle}" Content="Icons" Click="IconsViewButton_Click" />
                        <ToggleButton x:Name="DetailsPaneToggleButton" Style="{StaticResource ShellGlassToggleButtonStyle}" Content="Hide Pane" IsChecked="True" Click="DetailsPaneToggleButton_Click" />
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Content="Sync Pane" Click="SyncPaneLayout_Click" ToolTipService.ToolTip="Apply current pane layout to all tabs" />
                        <Button Style="{StaticResource ShellGlassButtonStyle}" AutomationProperties.Name="Keyboard shortcuts help" Content="Shortcuts" Click="ShortcutsHelp_Click" ToolTipService.ToolTip="Show keyboard shortcuts (F1)" />
                        <Button Style="{StaticResource ShellGlassButtonStyle}" Width="34" Height="32" Padding="0" CornerRadius="16" Click="OpenSettings_Click" ToolTipService.ToolTip="Settings" AutomationProperties.Name="Open settings">
                            <FontIcon Glyph="&#xE713;" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        
        <!-- Section: Main workspace -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="228" MinWidth="168" MaxWidth="360" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="DetailsPaneSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="DetailsPaneColumn" Width="340" MinWidth="250" MaxWidth="580" />
            </Grid.ColumnDefinitions>

            
            <!-- Section: Sidebar -->
            <Border Grid.Column="0" Margin="10,0,0,8" Background="{ThemeResource ShellSurfaceBackgroundBrush}" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.RowSpan="2" VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />

                    <TextBlock Grid.Row="0" Margin="16,14,16,7" Text="QUICK ACCESS" FontSize="10" FontWeight="SemiBold" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <ListView Grid.Row="1" x:Name="SidebarList" ItemContainerStyle="{StaticResource ShellListViewItemStyle}" ItemsSource="{Binding SidebarLocations}" SelectedItem="{Binding SelectedSidebar, Mode=TwoWay}" SelectionChanged="Sidebar_SelectionChanged" Padding="6,4" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Sidebar locations">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Padding="{Binding DataContext.SidebarPadding, ElementName=RootGrid}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <FontIcon FontSize="16" Glyph="{Binding Glyph}" Foreground="{ThemeResource ShellIconShadowBrush}" Margin="1,1,0,0" Opacity="0.42" />
                                        <FontIcon FontSize="16" Glyph="{Binding Glyph}" Foreground="{ThemeResource ShellIconForegroundBrush}" />
                                    </Grid>
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="0,8,0,16" Width="1" HorizontalAlignment="Center" Background="{ThemeResource ShellGlassEdgeSeparatorBrush}" Opacity="0.6" />

            
            <!-- Section: File list -->
            <Border Grid.Column="2" Margin="0,0,0,8" Background="{ThemeResource ShellSurfaceBackgroundBrush}" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.RowSpan="2" VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />

                    <TextBlock Grid.Row="0" Margin="14,10,14,2" Text="{Binding SelectedTab.CurrentPath}" FontSize="12" Foreground="{ThemeResource ShellButtonForegroundBrush}" TextTrimming="CharacterEllipsis" />

                    <Grid Grid.Row="1">
                        <ListView x:Name="FileList" ItemContainerStyle="{StaticResource ShellListViewItemStyle}" ItemsSource="{Binding SelectedTab.Items}" SelectionMode="Extended" SelectionChanged="FileList_SelectionChanged" Tapped="FileList_Tapped" DoubleTapped="FileList_DoubleTapped" RightTapped="FileList_RightTapped" CanDragItems="True" AllowDrop="True" DragItemsStarting="FileList_DragItemsStarting" DragOver="FileList_DragOver" Drop="FileList_Drop" Visibility="{Binding SelectedTab.ViewState.ViewMode, Converter={StaticResource ViewModeToVisibilityConverter}, ConverterParameter=Details}" Padding="0" AutomationProperties.Name="Files and folders list">
                            <ListView.Header>
                                <Grid Padding="40,10,16,10" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ShellSubtleBorderBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="160" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Click="SortName_Click" Content="NAME" FontWeight="SemiBold" FontSize="10" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" UseSystemFocusVisuals="True" />
                                    <Button Grid.Column="1" Click="SortType_Click" Content="TYPE" FontWeight="SemiBold" FontSize="10" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" UseSystemFocusVisuals="True" />
                                    <Button Grid.Column="2" Click="SortDate_Click" Content="DATE MODIFIED" FontWeight="SemiBold" FontSize="10" CharacterSpacing="120" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Padding="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" UseSystemFocusVisuals="True" />
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="{Binding DataContext.RowPadding, ElementName=RootGrid}" ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <Grid Grid.Column="0">
                                            <FontIcon FontSize="18" Glyph="{Binding IsDirectory, Converter={StaticResource FileItemGlyphConverter}}" Foreground="{ThemeResource ShellIconShadowBrush}" Margin="1,1,0,0" Opacity="0.55" />
                                            <FontIcon FontSize="18" Glyph="{Binding IsDirectory, Converter={StaticResource FileItemGlyphConverter}}" Foreground="{Binding IsDirectory, Converter={StaticResource FileItemTintBrushConverter}}" />
                                        </Grid>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13" />
                                        <TextBlock Grid.Column="2" Text="{Binding TypeDisplay}" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                                        <TextBlock Grid.Column="3" Text="{Binding ModifiedDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ContextFlyout>
                                <MenuFlyout Opening="FileListContextFlyout_Opening">
                                    <MenuFlyoutItem x:Name="OpenMenuItem" Text="Open" Click="OpenSelectedMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="CopyMenuItem" Text="Copy" Click="CopySelectedMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="CutMenuItem" Text="Cut" Click="CutSelectedMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="PasteMenuItem" Text="Paste" Click="PasteMenuItem_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="RenameMenuItem" Text="Rename" Click="RenameSelectedMenuItem_Click" />
                                    <MenuFlyoutItem x:Name="DeleteMenuItem" Text="Delete" Click="DeleteSelectedMenuItem_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="PropertiesMenuItem" Text="Properties" Click="PropertiesMenuItem_Click" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="New Folder" Click="NewFolderMenuItem_Click" />
                                </MenuFlyout>
                            </ListView.ContextFlyout>
                        </ListView>

                        <ListView x:Name="CompactFileList" ItemContainerStyle="{StaticResource ShellListViewItemStyle}" ItemsSource="{Binding SelectedTab.Items}" SelectionMode="Extended" SelectionChanged="FileList_SelectionChanged" Tapped="FileList_Tapped" DoubleTapped="FileList_DoubleTapped" RightTapped="FileList_RightTapped" CanDragItems="True" AllowDrop="True" DragItemsStarting="FileList_DragItemsStarting" DragOver="FileList_DragOver" Drop="FileList_Drop" Visibility="{Binding SelectedTab.ViewState.ViewMode, Converter={StaticResource ViewModeToVisibilityConverter}, ConverterParameter=Compact}" Padding="0" AutomationProperties.Name="Compact files and folders list">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,3" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" FontSize="15" Glyph="{Binding IsDirectory, Converter={StaticResource FileItemGlyphConverter}}" Foreground="{Binding IsDirectory, Converter={StaticResource FileItemTintBrushConverter}}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="12" />
                                        <TextBlock Grid.Column="2" Text="{Binding ModifiedDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <GridView x:Name="IconFileGrid" ItemContainerStyle="{StaticResource ShellGridViewItemStyle}" ItemsSource="{Binding SelectedTab.Items}" SelectionMode="Extended" SelectionChanged="FileList_SelectionChanged" Tapped="FileList_Tapped" DoubleTapped="FileList_DoubleTapped" RightTapped="FileList_RightTapped" CanDragItems="True" AllowDrop="True" DragItemsStarting="FileList_DragItemsStarting" DragOver="FileList_DragOver" Drop="FileList_Drop" Visibility="{Binding SelectedTab.ViewState.ViewMode, Converter={StaticResource ViewModeToVisibilityConverter}, ConverterParameter=Icons}" Padding="8" AutomationProperties.Name="Icon files and folders grid">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Width="110" Height="92" Padding="10" Spacing="6" HorizontalAlignment="Center">
                                        
                                        <Grid HorizontalAlignment="Center">
                                            <FontIcon FontSize="32" Glyph="{Binding IsDirectory, Converter={StaticResource FileItemGlyphConverter}}" Foreground="{ThemeResource ShellIconShadowBrush}" Margin="1,2,0,0" Opacity="0.55" />
                                            <FontIcon FontSize="32" Glyph="{Binding IsDirectory, Converter={StaticResource FileItemGlyphConverter}}" Foreground="{Binding IsDirectory, Converter={StaticResource FileItemTintBrushConverter}}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Name}" TextAlignment="Center" TextTrimming="CharacterEllipsis" MaxLines="2" FontSize="12" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <TextBlock
                            Text="No items in this location"
                            FontSize="14"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding SelectedTab.Items.Count, Converter={StaticResource ZeroCountToVisibilityConverter}}" />

                        <ProgressRing IsActive="{Binding SelectedTab.IsBusy}" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" />

                        <TextBlock Text="{Binding SelectedTab.ErrorMessage}" Foreground="{ThemeResource SystemFillColorCriticalBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding SelectedTab.ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                    </Grid>
                </Grid>
            </Border>

            <Button
                x:Name="DetailsPaneSplitter"
                Grid.Column="3"
                Background="{ThemeResource ShellSplitterBrush}"
                BorderThickness="0"
                Padding="0"
                ToolTipService.ToolTip="Drag or use Left and Right arrow keys to resize details pane. Press Ctrl+Shift+D to focus splitter."
                AutomationProperties.Name="Details pane splitter"
                AutomationProperties.HelpText="Use left and right arrow keys to resize details pane. Use Home and End for minimum and maximum width."
                AutomationProperties.AcceleratorKey="Ctrl+Shift+D"
                PointerPressed="DetailsSplitter_PointerPressed"
                PointerMoved="DetailsSplitter_PointerMoved"
                PointerReleased="DetailsSplitter_PointerReleased"
                PointerCanceled="DetailsSplitter_PointerCanceled"
                KeyDown="DetailsSplitter_KeyDown" />

            
            <!-- Section: Details and preview pane -->
            <Border x:Name="DetailsPaneHost" Grid.Column="4" Margin="0,0,10,8" Background="{ThemeResource ShellSurfaceBackgroundBrush}" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" BorderThickness="1" CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Rectangle Grid.RowSpan="3" VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />

                    <TextBlock Grid.Row="0" Margin="14,12,14,4" Text="Details &amp; Preview" FontWeight="SemiBold" Foreground="{ThemeResource ShellButtonForegroundBrush}" />
                    <TextBlock Grid.Row="1" Margin="14,0,14,8" Text="{Binding SelectedTab.SelectionSummary}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                    <ScrollViewer x:Name="DetailsPaneScrollViewer" Grid.Row="2" Margin="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" IsTabStop="True" UseSystemFocusVisuals="True" AutomationProperties.Name="Details and preview pane">
                        <StackPanel Spacing="10" Padding="14,0,14,14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Name" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding SelectedTab.PrimarySelection.Name}" TextWrapping="Wrap" Visibility="{Binding SelectedTab.PrimarySelection, Converter={StaticResource NullToCollapsedConverter}}" />

                                <TextBlock Text="Type" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedTab.PrimarySelection.TypeDisplay}" TextWrapping="Wrap" Visibility="{Binding SelectedTab.PrimarySelection, Converter={StaticResource NullToCollapsedConverter}}" />

                                <TextBlock Text="Path" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedTab.PrimarySelection.FullPath}" TextWrapping="Wrap" Visibility="{Binding SelectedTab.PrimarySelection, Converter={StaticResource NullToCollapsedConverter}}" />

                                <TextBlock Text="Modified" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedTab.PrimarySelection.ModifiedDisplay}" TextWrapping="Wrap" Visibility="{Binding SelectedTab.PrimarySelection, Converter={StaticResource NullToCollapsedConverter}}" />

                                <TextBlock Text="Size" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SelectedTab.PrimarySelection.SizeDisplay}" TextWrapping="Wrap" Visibility="{Binding SelectedTab.PrimarySelection, Converter={StaticResource NullToCollapsedConverter}}" />
                            </StackPanel>

                            <Border Height="1" Background="{ThemeResource ShellSubtleBorderBrush}" />

                            <TextBlock Text="Preview" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedTab.PreviewMessage}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />

                            <ProgressRing IsActive="{Binding SelectedTab.IsPreviewLoading}" Width="28" Height="28" HorizontalAlignment="Left" />

                            <Border BorderBrush="{ThemeResource ShellSubtleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="6" Background="{ThemeResource ShellInputBackgroundBrush}" Visibility="{Binding SelectedTab.PreviewImagePath, Converter={StaticResource NullToCollapsedConverter}}">
                                <Grid>
                                    <Rectangle VerticalAlignment="Top" Height="2" Margin="4,1,4,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                    <Image
                                        Source="{Binding SelectedTab.PreviewImagePath, Converter={StaticResource FilePathToImageSourceConverter}}"
                                        Stretch="Uniform"
                                        MaxHeight="360"
                                        MinWidth="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <Border BorderBrush="{ThemeResource ShellSubtleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="6" Background="{ThemeResource ShellInputBackgroundBrush}" Visibility="{Binding SelectedTab.PreviewMediaPath, Converter={StaticResource NullToCollapsedConverter}}">
                                <Grid>
                                    <Rectangle VerticalAlignment="Top" Height="2" Margin="4,1,4,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                    <MediaPlayerElement
                                        x:Name="PreviewMediaPlayer"
                                        Source="{Binding SelectedTab.PreviewMediaPath, Converter={StaticResource FilePathToMediaSourceConverter}}"
                                        AreTransportControlsEnabled="True"
                                        AutoPlay="False"
                                        Stretch="Uniform"
                                        MinHeight="140"
                                        MaxHeight="360"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch" />
                                </Grid>
                            </Border>

                            <Border BorderBrush="{ThemeResource ShellSubtleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="8" Background="{ThemeResource ShellInputBackgroundBrush}" Visibility="{Binding SelectedTab.PreviewText, Converter={StaticResource NullToCollapsedConverter}}">
                                <Grid>
                                    <Rectangle VerticalAlignment="Top" Height="2" Margin="4,1,4,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" MaxHeight="300">
                                        <TextBlock
                                            Text="{Binding SelectedTab.PreviewText}"
                                            TextWrapping="Wrap"
                                            FontFamily="Cascadia Mono"
                                            FontSize="12" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border
            x:Name="SyncToastHost"
            Grid.Row="4"
            Margin="0,12,16,0"
            Padding="12,8"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            MaxWidth="460"
            CornerRadius="10"
            Background="{ThemeResource ShellToastBackgroundBrush}"
            BorderBrush="{ThemeResource ShellToastBorderBrush}"
            BorderThickness="1"
            Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontFamily="{ThemeResource SymbolThemeFontFamily}" Foreground="{ThemeResource ShellToastIconForegroundBrush}" VerticalAlignment="Center" />
                <TextBlock x:Name="SyncToastText" Grid.Column="1" Foreground="{ThemeResource ShellToastForegroundBrush}" FontSize="12" TextWrapping="Wrap" />
            </Grid>
        </Border>

        
        <!-- Section: Status bar -->
        <Border Grid.Row="5" Margin="10,0,10,8" CornerRadius="10" BorderThickness="1" BorderBrush="{ThemeResource ShellSurfaceBorderBrush}" Background="{ThemeResource ShellSurfaceBackgroundBrush}">
            <Grid>
                <Rectangle VerticalAlignment="Top" Height="2" Margin="6,1,6,0" RadiusX="1" RadiusY="1" Fill="{ThemeResource ShellPanelHighlightStripBrush}" IsHitTestVisible="False" />
                <Grid Margin="12,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusLine}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" AutomationProperties.Name="Status" AutomationProperties.LiveSetting="Polite" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Style="{StaticResource ShellGlassButtonStyle}" Padding="10,4" Click="OpenOperationsQueue_Click" ToolTipService.ToolTip="Open operation queue inspector">
                        <TextBlock Text="{Binding OperationsSummary}" FontSize="11" />
                    </Button>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>

