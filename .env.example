# Files++ build defaults
FILESPP_CONFIGURATION=Release
FILESPP_RUNTIME_IDENTIFIER=win-x64
FILESPP_WINDOWS_TFM=net10.0-windows10.0.22621.0
FILESPP_PROJECT_PATH=src/FilesPlusPlus.App/FilesPlusPlus.App.csproj
FILESPP_OUTPUT_ROOT=artifacts
FILESPP_DOTNET_CLI_HOME=.dotnet-cli-home

# MSIX packaging
FILESPP_MSIX_VERSION=1.0.0.0
FILESPP_MSIX_BUILD_MODE=SideloadOnly
FILESPP_MSIX_SIGNING_ENABLED=false
FILESPP_MSIX_CERT_PFX_PATH=
FILESPP_MSIX_CERT_PASSWORD=

# MSI packaging
FILESPP_MSI_VERSION=1.0.0
FILESPP_MSI_WIX_ARCH=x64
FILESPP_MSI_WIX_SOURCE=scripts/wix/FilesPlusPlus.wxs
FILESPP_WIX_PATH=

# GitHub release wiring
FILESPP_RELEASE_ASSET_ROOTS=artifacts/msix,artifacts/msi
FILESPP_RELEASE_TAG=
FILESPP_GH_REPO=
GH_TOKEN=
